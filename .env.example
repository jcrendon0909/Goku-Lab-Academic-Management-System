# Copia a server/.env y completa los valores

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/goku_lab

# API (Express)
PORT=4000
NODE_ENV=development
JWT_SECRET=genera-un-secreto-largo-y-aleatorio

# En producción: dominio(s) del frontend, separados por coma
CORS_ORIGIN=http://localhost:5173

# Frontend (copia a .env en la raíz del proyecto Vite)
# VITE_API_URL=http://localhost:4000/api
